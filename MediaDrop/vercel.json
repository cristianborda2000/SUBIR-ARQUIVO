{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/server.js": {
      "maxDuration": 60,
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/src/server.js"
    },
    {
      "source": "/admin",
      "destination": "/src/server.js"
    }
  ]
}
